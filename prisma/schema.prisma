generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum MessageStatus {
  PENDING
  COMPLETE
  ERROR
  CANCELLED
}

enum GenerationRunType {
  PERSONA_DRAFT
  PERSONA_AVATAR
}

enum GenerationRunStatus {
  PENDING
  COMPLETE
  ERROR
  CANCELLED
}

enum MemoryScope {
  GLOBAL
  PERSONA
}

enum MemoryOrigin {
  MANUAL
  CHAT_MESSAGE
  AUTO_EXTRACTED
}

enum ToolType {
  SUMMARIZE
  REWRITE
  TRANSLATE
  IMAGE_ANALYZE
  IMAGE_GENERATE
  BRAINSTORM
}

enum BrainstormWorkerRole {
  ANALYST
  CREATIVE
  CRITIC
  PLANNER
}

enum BrainstormWorkerStatus {
  PENDING
  COMPLETE
  ERROR
  CANCELLED
}

enum AgentRunMode {
  STANDARD
  DEEP
}

enum AgentRunStatus {
  PENDING
  COMPLETE
  ERROR
  CANCELLED
}

enum AgentRunPhase {
  PLANNING
  DISPATCHING
  WORKING
  SYNTHESIZING
  FINISHED
}

enum AgentWorkerStatus {
  QUEUED
  BLOCKED
  RUNNING
  COMPLETE
  ERROR
  CANCELLED
  TIMEOUT
}

enum AgentPriority {
  HIGH
  MEDIUM
  LOW
}

enum AgentEventType {
  RUN_CREATED
  PLANNING_STARTED
  PLAN_CREATED
  PLAN_FALLBACK
  WORKERS_CREATED
  WORKER_QUEUED
  WORKER_BLOCKED
  WORKER_STARTED
  WORKER_COMPLETED
  WORKER_FAILED
  WORKER_CANCELLED
  WORKER_TIMEOUT
  SYNTHESIS_STARTED
  RUN_COMPLETED
  RUN_FAILED
  RUN_CANCELLED
  RUN_TIMEOUT
}

enum GeneratedImageKind {
  PERSONA_AVATAR
  TOOL_GENERATION
}

enum ToolAssetKind {
  IMAGE
}

enum ToolRunStatus {
  PENDING
  COMPLETE
  ERROR
  CANCELLED
}

enum UsageCapability {
  CHAT_MESSAGE
  TOOL_SUMMARIZE
  TOOL_REWRITE
  TOOL_TRANSLATE
  IMAGE_ANALYZE
  IMAGE_GENERATE
  BRAINSTORM
  AGENT_STANDARD
  AGENT_DEEP
}

model Profile {
  id            String   @id @db.Uuid
  email         String   @unique
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  role          Role     @default(USER)
  memoryEnabled Boolean  @default(true) @map("memory_enabled")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  personas          Persona[]
  conversations     Conversation[]
  memories          Memory[]
  memoryEmbeddings  MemoryEmbedding[]
  images            GeneratedImage[]
  toolRuns          ToolRun[]
  toolAssets        ToolAsset[]
  generationRuns    GenerationRun[]
  brainstormWorkers BrainstormWorker[]
  agentRuns         AgentRun[]
  agentWorkers      AgentWorker[]
  agentEvents       AgentEvent[]
  usageLedger       UsageLedger[]

  @@map("profiles")
}

model UsageLedger {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  capability     UsageCapability
  units          Int             @default(1)
  runId          String          @map("run_id") @db.Uuid
  idempotencyKey String          @map("idempotency_key") @db.VarChar(200)
  provider       String?         @db.VarChar(100)
  model          String?         @db.VarChar(200)
  inputTokens    Int?            @map("input_tokens")
  outputTokens   Int?            @map("output_tokens")
  estimatedCost  Decimal?        @map("estimated_cost") @db.Decimal(18, 8)
  pricingVersion String?         @map("pricing_version") @db.VarChar(50)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, runId])
  @@unique([userId, idempotencyKey])
  @@index([userId, capability, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("usage_ledger")
}

model ToolRun {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  type              ToolType
  status            ToolRunStatus @default(PENDING)
  title             String?       @db.VarChar(100)
  inputText         String?       @map("input_text") @db.Text
  outputText        String?       @map("output_text") @db.Text
  options           Json
  retainContent     Boolean       @default(true) @map("retain_content")
  errorCode         String?       @map("error_code") @db.VarChar(100)
  recoveryExpiresAt DateTime?     @map("recovery_expires_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              Profile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets            ToolAsset[]
  generatedImage    GeneratedImage?
  brainstormWorkers BrainstormWorker[]

  @@unique([id, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("tool_runs")
}

model BrainstormWorker {
  id          String                 @id @default(uuid()) @db.Uuid
  toolRunId   String                 @map("tool_run_id") @db.Uuid
  userId      String                 @map("user_id") @db.Uuid
  role        BrainstormWorkerRole
  position    Int
  status      BrainstormWorkerStatus @default(PENDING)
  outputText  String?                @map("output_text") @db.Text
  errorCode   String?                @map("error_code") @db.VarChar(100)
  startedAt   DateTime?              @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?              @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  toolRun ToolRun @relation(fields: [toolRunId, userId], references: [id, userId], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toolRunId, role])
  @@unique([toolRunId, position])
  @@index([userId, createdAt(sort: Desc)])
  @@index([toolRunId, status])
  @@map("brainstorm_workers")
}

model GenerationRun {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  personaId String?             @map("persona_id") @db.Uuid
  type      GenerationRunType
  status    GenerationRunStatus @default(PENDING)
  input     Json
  result    Json?
  errorCode String?             @map("error_code") @db.VarChar(100)
  expiresAt DateTime            @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona Persona? @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([personaId, type, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("generation_runs")
}

model ToolAsset {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  toolRunId   String        @map("tool_run_id") @db.Uuid
  kind        ToolAssetKind @default(IMAGE)
  storagePath String        @map("storage_path")
  mimeType    String        @map("mime_type") @db.VarChar(100)
  sizeBytes   Int           @map("size_bytes")
  width       Int
  height      Int
  sha256      String        @db.VarChar(64)
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolRun ToolRun @relation(fields: [toolRunId], references: [id], onDelete: Cascade)

  @@unique([toolRunId])
  @@index([userId, expiresAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("tool_assets")
}

model Persona {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String
  avatarUrl     String?   @map("avatar_url")
  avatarPrompt  String?   @map("avatar_prompt")
  avatarImageId String?   @unique @map("avatar_image_id") @db.Uuid
  description   String?
  personality   String
  identity      String?
  speakingStyle String?   @map("speaking_style")
  expertise     String?
  greeting      String?
  systemPrompt  String    @map("system_prompt")
  archivedAt    DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user           Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  memories       Memory[]
  avatarImage    GeneratedImage? @relation("PersonaAvatarImage", fields: [avatarImageId], references: [id], onDelete: SetNull)
  generationRuns GenerationRun[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, archivedAt, updatedAt(sort: Desc)])
  @@map("personas")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  personaId String?  @map("persona_id") @db.Uuid
  title     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona   Persona?   @relation(fields: [personaId], references: [id], onDelete: SetNull)
  messages  Message[]
  memories  Memory[]
  agentRuns AgentRun[]

  @@unique([id, userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String
  status         MessageStatus @default(COMPLETE)
  provider       String?
  model          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  supersededAt   DateTime?     @map("superseded_at") @db.Timestamptz(6)

  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sourceMemories      Memory[]     @relation("MemorySourceMessage")
  agentRunAsUser      AgentRun?    @relation("AgentRunUserMessage")
  agentRunAsAssistant AgentRun?    @relation("AgentRunAssistantMessage")

  @@unique([id, conversationId])
  @@index([conversationId, createdAt])
  @@index([conversationId, supersededAt, createdAt])
  @@map("messages")
}

model AgentRun {
  id                    String         @id @default(uuid()) @db.Uuid
  userId                String         @map("user_id") @db.Uuid
  conversationId        String         @map("conversation_id") @db.Uuid
  userMessageId         String         @map("user_message_id") @db.Uuid
  assistantMessageId    String         @map("assistant_message_id") @db.Uuid
  mode                  AgentRunMode
  status                AgentRunStatus @default(PENDING)
  phase                 AgentRunPhase  @default(PLANNING)
  planOverview          String?        @map("plan_overview") @db.Text
  planFallback          Boolean        @default(false) @map("plan_fallback")
  plannedWorkerCount    Int            @map("planned_worker_count")
  completedWorkerCount  Int            @default(0) @map("completed_worker_count")
  successfulWorkerCount Int            @default(0) @map("successful_worker_count")
  providerCallCount     Int            @default(0) @map("provider_call_count")
  errorCode             String?        @map("error_code") @db.VarChar(100)
  startedAt             DateTime       @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation  @relation(fields: [conversationId, userId], references: [id, userId], onDelete: Cascade)
  userMessage      Message       @relation("AgentRunUserMessage", fields: [userMessageId, conversationId], references: [id, conversationId], onDelete: Cascade)
  assistantMessage Message       @relation("AgentRunAssistantMessage", fields: [assistantMessageId, conversationId], references: [id, conversationId], onDelete: Cascade)
  workers          AgentWorker[]
  events           AgentEvent[]

  @@unique([id, userId])
  @@unique([userMessageId, conversationId])
  @@unique([assistantMessageId, conversationId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, mode, status, createdAt(sort: Desc)])
  @@index([conversationId, createdAt])
  @@map("agent_runs")
}

model AgentWorker {
  id                  String            @id @default(uuid()) @db.Uuid
  agentRunId          String            @map("agent_run_id") @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  key                 String            @db.VarChar(64)
  position            Int
  name                String            @db.VarChar(80)
  title               String            @db.VarChar(160)
  objective           String            @db.VarChar(1200)
  expectedDeliverable String            @map("expected_deliverable") @db.VarChar(1200)
  priority            AgentPriority
  status              AgentWorkerStatus @default(QUEUED)
  dependsOnKeys       String[]          @default([]) @map("depends_on_keys")
  workSummary         String?           @map("work_summary") @db.VarChar(1200)
  findings            String[]          @default([])
  assumptions         String[]          @default([])
  risks               String[]          @default([])
  recommendations     String[]          @default([])
  finalDeliverable    String?           @map("final_deliverable") @db.Text
  structured          Boolean           @default(false)
  providerCallCount   Int               @default(0) @map("provider_call_count")
  errorCode           String?           @map("error_code") @db.VarChar(100)
  startedAt           DateTime?         @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?         @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  agentRun AgentRun @relation(fields: [agentRunId, userId], references: [id, userId], onDelete: Cascade)
  user     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentRunId, key])
  @@unique([agentRunId, position])
  @@index([userId, createdAt(sort: Desc)])
  @@index([agentRunId, status])
  @@map("agent_workers")
}

model AgentEvent {
  id          String         @id @default(uuid()) @db.Uuid
  agentRunId  String         @map("agent_run_id") @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  sequence    Int
  type        AgentEventType
  workerKey   String?        @map("worker_key") @db.VarChar(64)
  summaryText String?        @map("summary_text") @db.VarChar(500)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  agentRun AgentRun @relation(fields: [agentRunId, userId], references: [id, userId], onDelete: Cascade)
  user     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentRunId, sequence])
  @@index([userId, createdAt(sort: Desc)])
  @@index([agentRunId, type, createdAt])
  @@map("agent_events")
}

model Memory {
  id                   String       @id @default(uuid()) @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  personaId            String?      @map("persona_id") @db.Uuid
  content              String
  category             String
  scope                MemoryScope  @default(GLOBAL)
  origin               MemoryOrigin @default(MANUAL)
  importance           Int          @default(3)
  sourceConversationId String?      @map("source_conversation_id") @db.Uuid
  sourceMessageId      String?      @map("source_message_id") @db.Uuid
  enabled              Boolean      @default(true)
  lastUsedAt           DateTime?    @map("last_used_at") @db.Timestamptz(6)
  topicKey             String?      @map("topic_key")
  keywords             String[]     @default([])
  pinned               Boolean      @default(false)
  useCount             Int          @default(0) @map("use_count")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user               Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona            Persona?         @relation(fields: [personaId], references: [id], onDelete: Cascade)
  sourceConversation Conversation?    @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)
  sourceMessage      Message?         @relation("MemorySourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  embedding          MemoryEmbedding?

  @@index([userId, enabled, scope, importance, updatedAt(sort: Desc)])
  @@index([personaId, enabled, importance])
  @@index([sourceMessageId])
  @@index([userId, pinned, enabled, importance])
  @@index([userId, topicKey])
  @@index([personaId, topicKey])
  @@map("memories")
}

model MemoryEmbedding {
  memoryId    String                     @id @map("memory_id") @db.Uuid
  userId      String                     @map("user_id") @db.Uuid
  model       String
  dimensions  Int
  contentHash String                     @map("content_hash")
  embedding   Unsupported("vector(512)")
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  memory Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, model, dimensions])
  @@map("memory_embeddings")
}

model GeneratedImage {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  kind          GeneratedImageKind @default(PERSONA_AVATAR)
  prompt        String
  provider      String
  model         String
  storagePath   String             @map("storage_path")
  storageBucket String             @default("persona-avatars") @map("storage_bucket") @db.VarChar(100)
  mimeType      String?            @map("mime_type") @db.VarChar(100)
  sizeBytes     Int?               @map("size_bytes")
  width         Int?
  height        Int?
  toolRunId     String?            @unique @map("tool_run_id") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  user          Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaAvatar Persona? @relation("PersonaAvatarImage")
  toolRun       ToolRun? @relation(fields: [toolRunId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([toolRunId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, kind, createdAt(sort: Desc)])
  @@map("generated_images")
}

model ModelConfig {
  id           String   @id @default(uuid()) @db.Uuid
  provider     String
  model        String
  capabilities String[]
  enabled      Boolean  @default(true)
  parameters   Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([provider, model])
  @@map("model_configs")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("app_settings")
}
